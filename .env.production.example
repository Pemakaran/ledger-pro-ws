# LedgerPro Realtime — production env (copy to .env on the droplet, chmod 600).
# Never commit the real .env. See docs/DEPLOY.md for the full rollout.

# ── Runtime ──────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# The frontend origin — MUST match the backend's CORS_ORIGIN. Never '*' in prod.
CORS_ORIGIN=https://app.ledgerpro.shop

# ── Redis (event bus + socket.io adapter) ────────────────
# The shared redis from the backend prod stack, reached over `ledgerpro-network`
# by its service name. Must equal the backend's REDIS_URL.
REDIS_URL=redis://redis:6379
REALTIME_REDIS_CHANNEL=ledgerpro:realtime

# ── Auth bridge (RS256 / JWKS — no shared secret) ────────
# The backend serves its public keys here; reached internally over the shared
# network (NOT the public api.<domain>), so realtime never leaves the droplet to
# verify a token. Must match the backend's JWT_ISSUER / JWT_AUDIENCE.
JWKS_URI=http://backend:3000/.well-known/jwks.json
JWT_ISSUER=ledgerpro-backend
JWT_AUDIENCE=ledgerpro-api
