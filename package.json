{
  "name": "ledgerpro-realtime",
  "version": "0.1.0",
  "description": "LedgerPro realtime service — JWKS-authenticated WebSocket delivery (notifications, system-alert live-refresh) and chat. Pairs with the LedgerPro backend over Redis pub/sub.",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ]
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start -e \"node -r ./tsconfig-paths-bootstrap.js\"",
    "start:dev": "nest start --watch -e \"node -r ./tsconfig-paths-bootstrap.js\"",
    "start:debug": "nest start --debug --watch -e \"node -r ./tsconfig-paths-bootstrap.js\"",
    "start:prod": "node -r ./tsconfig-paths-bootstrap.js dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "verify": "pnpm run lint && pnpm run test && pnpm run build",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "11.1.14",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.14",
    "@nestjs/platform-express": "11.1.14",
    "@nestjs/platform-socket.io": "11.1.14",
    "@nestjs/websockets": "11.1.14",
    "@socket.io/redis-adapter": "8.3.0",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "jwks-rsa": "3.1.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "tsconfig-paths": "4.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.4",
    "@eslint/js": "9.39.3",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.14",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.19.11",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "jest": "30.2.0",
    "prettier": "3.8.1",
    "source-map-support": "0.5.21",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*?)(?:\\.js)?$": "<rootDir>/$1",
      "^@common/(.*?)(?:\\.js)?$": "<rootDir>/common/$1",
      "^@realtime/(.*?)(?:\\.js)?$": "<rootDir>/realtime/$1",
      "^@health/(.*?)(?:\\.js)?$": "<rootDir>/health/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
