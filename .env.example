# ---- Runtime ----
NODE_ENV=development
PORT=3001
# Lock to the frontend origin in prod; '*' only for local dev.
CORS_ORIGIN=*

# ---- Redis (event bus + socket.io adapter) ----
REDIS_URL=redis://localhost:6379
# Channel the backend PUBLISHes realtime envelopes on.
REALTIME_REDIS_CHANNEL=ledgerpro:realtime

# ---- Auth bridge ----
# JWKS endpoint of the main LedgerPro backend (RS256 public keys). No shared secret.
#   host (pnpm start:dev):      http://localhost:3000/.well-known/jwks.json
#   docker-compose (dev):       http://host.docker.internal:3000/.well-known/jwks.json
#   droplet (shared network):   http://backend:3000/.well-known/jwks.json
JWKS_URI=http://localhost:3000/.well-known/jwks.json
# Must match the backend's JWT_ISSUER / JWT_AUDIENCE (jwt.config.ts defaults).
JWT_ISSUER=ledgerpro-backend
JWT_AUDIENCE=ledgerpro-api
